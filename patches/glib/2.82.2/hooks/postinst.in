#!@TERMUX_PREFIX_CLASSICAL@/bin/sh

# glib-compile-schemas is located in glib-bin package which
# may not be installed.
unset LD_PRELOAD
if [ -f "/data/data/com.winlator/files/imagefs/usr/bin/glib-compile-schemas" ]; then
	/data/data/com.winlator/files/imagefs/usr/bin/glib-compile-schemas "/data/data/com.winlator/files/imagefs/usr/share/glib-2.0/schemas" > /dev/null
fi

exit 0
